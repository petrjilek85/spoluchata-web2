    <!-- FOOTER -->
    <footer class="bg-forest-900 text-forest-100/60 py-6 text-center text-xs border-t border-forest-800">
        &copy; 2026 Spoluchata.cz. Všechna práva vyhrazena.
    </footer>

    <!-- LOGIKA PRO VÍCEKROKOVÝ FORMULÁŘ -->
    <script>
        // Inicializace ikon
        lucide.createIcons();

        // Nastavení kroků formuláře
        let currentStep = 1;
        const totalSteps = 4;

        const stepTitles = {
            1: "Krok 1 z 4: O vás a vaší posádce",
            2: "Krok 2 z 4: Styl chataření a soužití",
            3: "Krok 3 z 4: Vysněná chata a lokalita",
            4: "Krok 4 z 4: Finance a závazek"
        };

        const form = document.getElementById('matching-form');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const submitBtn = document.getElementById('submit-btn');
        const successScreen = document.getElementById('success-screen');

        function updateFormUI() {
            // Skrýt všechny sekce
            document.querySelectorAll('.step-section').forEach(section => section.classList.add('hidden'));
            
            // Zobrazit aktivní sekci
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');

            // Aktualizace progress baru
            const percent = (currentStep / totalSteps) * 100;
            document.getElementById('step-bar').style.width = `${percent}%`;
            document.getElementById('step-percent').innerText = `${Math.round(percent)}%`;
            document.getElementById('step-title').innerText = stepTitles[currentStep];

            // Tlačítka zpět / vpřed
            if (currentStep === 1) {
                prevBtn.classList.add('hidden');
            } else {
                prevBtn.classList.remove('hidden');
            }

            if (currentStep === totalSteps) {
                nextBtn.classList.add('hidden');
                submitBtn.classList.remove('hidden');
            } else {
                nextBtn.classList.remove('hidden');
                submitBtn.classList.add('hidden');
            }
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Ověření, zda jsou v aktuálním kroku vyplněna povinná pole
        function validateStep() {
            const currentSection = document.getElementById(`step-${currentStep}`);
            const requiredInputs = currentSection.querySelectorAll('[required]');
            
            for (let input of requiredInputs) {
                if (input.type === 'radio') {
                    // Najít všechny radio se stejným jménem v této sekci
                    const name = input.name;
                    const checked = currentSection.querySelector(`input[name="${name}"]:checked`);
                    if (!checked) {
                        alert('Prosím, vyplňte všechny povinné otázky.');
                        return false;
                    }
                } else if (!input.value.trim()) {
                    input.focus();
                    alert('Prosím, vyplňte toto pole.');
                    return false;
                }
            }
            return true;
        }

        // Tlačítko Další
        nextBtn.addEventListener('click', () => {
            if (validateStep()) {
                currentStep++;
                updateFormUI();
            }
        });

        // Tlačítko Zpět
        prevBtn.addEventListener('click', () => {
            currentStep--;
            updateFormUI();
        });

        // Odeslání formuláře na Web3Forms
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!validateStep()) return;

            submitBtn.disabled = true;
            submitBtn.innerText = "Odesílám dotazník...";

            const formData = new FormData(form);

            try {
                const response = await fetch("https://api.web3forms.com/submit", {
                    method: "POST",
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    form.classList.add('hidden');
                    document.getElementById('step-title').parentElement.parentElement.classList.add('hidden');
                    successScreen.classList.remove('hidden');
                } else {
                    alert('Došlo k chybě při odesílání. Zkuste to prosím znovu.');
                    submitBtn.disabled = false;
                    submitBtn.innerText = "Odeslat dotazník";
                }
            } catch (error) {
                console.error("Error:", error);
                alert('Chyba spojení. Zkontrolujte připojení k internetu.');
                submitBtn.disabled = false;
                submitBtn.innerText = "Odeslat dotazník";
            }
        });

        // Spustit UI
        updateFormUI();
    </script>
</body>
</html>
