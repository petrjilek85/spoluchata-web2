                                <input type="radio" name="Mazlicci" value="Ano - Pes" required class="text-forest-600">
                                <span class="text-sm">Ano, psa</span>
                            </label>
                            <label class="flex items-center gap-2 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer transition-colors">
                                <input type="radio" name="Mazlicci" value="Ano - Jiny" class="text-forest-600">
                                <span class="text-sm">Ano, jiného mazlíčka</span>
                            </label>
                            <label class="flex items-center gap-2 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer transition-colors">
