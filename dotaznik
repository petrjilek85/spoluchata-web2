                                <span class="text-sm">Budu jezdit sám / v páru (bez dětí)</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer transition-colors">
                                <input type="radio" name="Slozeni_posadky" value="Rodina s detmi (do 6 let)" class="text-forest-600 focus:ring-forest-600">
                                <span class="text-sm">Rodina s malými dětmi (předškolní věk do 6 let)</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer transition-colors">
                                <input type="radio" name="Slozeni_posadky" value="Rodina s detmi (nad 6 let)" class="text-forest-600 focus:ring-forest-600">
                                <span class="text-sm">Rodina se staršími dětmi (školní věk)</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer transition-colors">
                                <input type="radio" name="Slozeni_posadky" value="Parta pratel" class="text-forest-600 focus:ring-forest-600">
                                <span class="text-sm">Parta přátel / kamarádi</span>
                            </label>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="text-sm font-semibold text-gray-700 block">Budete s sebou brát domácí mazlíčky?</label>
                        <div class="grid grid-cols-2 gap-3">
