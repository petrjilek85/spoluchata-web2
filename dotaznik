                        <div class="space-y-2">
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer">
                                <input type="radio" name="Rozpocet_mesicni" value="Do 3 000 Kc" required class="text-forest-600">
                                <span class="text-sm">Do 3 000 Kč / měsíčně</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer">
                                <input type="radio" name="Rozpocet_mesicni" value="3 000 - 5 000 Kc" class="text-forest-600">
                                <span class="text-sm">3 000 – 5 000 Kč / měsíčně</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl border hover:bg-forest-50/50 cursor-pointer">
                                <input type="radio" name="Rozpocet_mesicni" value="5 000 - 8 000 Kc" class="text-forest-600">
                                <span class="text-sm">5 000 – 8 000 Kč / měsíčně</span>
